{
    "cmake.generator": "Ninja",
    "cmake.buildDirectory": "${workspaceFolder}/../Debug/build/Thunder",
    "cmake.buildTask": true,
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
    "C_Cpp.default.compileCommands": "${workspaceFolder}/../Debug/build/Thunder/compile_commands.json",
    "cmake.configureSettings": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_INSTALL_PREFIX": "${workspaceFolder}/../Debug/install/usr",
        "CMAKE_VERBOSE_MAKEFILE": "ON",
        "CMAKE_PREFIX_PATH": "${workspaceFolder}/../Debug/install/usr",
        "CMAKE_MODULE_PATH": "${workspaceFolder}/../Debug/install/usr/include/Thunder/Modules",
        "DATA_PATH": "${workspaceFolder}/../Debug/install/usr/share/Thunder",
        "PERSISTENT_PATH": "${workspaceFolder}/../Debug/install/usr/var/Thunder",
        "PROXY_STUB_PATH": "${workspaceFolder}/../Debug/install/usr/lib/Thunder/ProxyStubs",
        "SYSTEM_PATH": "${workspaceFolder}/../Debug/install/usr/lib/Thunder/Plugins",
        "VOLATILE_PATH": "/tmp",
        "BINDING": "0.0.0.0",
        "PORT": "55555",
        "BUILD_TESTS": "ON",
        "GTEST_INCLUDE_DIR": "/usr/include",
        "ENABLE_CODE_COVERAGE": "OFF"
    },
    "terminal.integrated.allowInUntrustedWorkspace": false
}